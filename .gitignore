# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Python
__pycache__/
*.pyc
*.pyo

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Local build config (generated by sccache-setup)
.cargo/

# PostgreSQL test setup (local installations and config)
pg-test-config.toml
testdata/

# Profiling artifacts
flamegraph.svg
perf.data
perf.data.old

# Coverage artifacts
lcov.info
coverage/

# TPC-H: generated data, dbgen binary, run output
# heatmap.html and checkpoints/current/ are kept (reference report + latest results)
benches/tpch/data_sf*/
benches/tpch/tpch-dbgen/
benches/tpch/results.csv
benches/tpch/results.json
benches/tpch/.output_staging/

# ClickBench: large dataset and run output
# heatmap.html and checkpoints/current/ are kept (reference report + latest results)
benches/clickbench/hits.tsv
benches/clickbench/results.csv
benches/clickbench/results.json
benches/clickbench/.output_staging/

# Test output/results
tests/consistency/results.txt
tests/sql_correctness/results.txt

# Large snapshots (full-table dumps, ~100k rows — not useful as diffs)
tests/sql_correctness/snapshots/query_extreme_values__6.snap
tests/sql_correctness/snapshots/query_memory_bound__1.snap
tests/sql_correctness/snapshots/query_memory_bound__2.snap
tests/sql_correctness/snapshots/query_compute_bound__1.snap
tests/sql_correctness/snapshots/query_compute_bound__3.snap
tests/sql_correctness/snapshots/query_compute_bound__5.snap
