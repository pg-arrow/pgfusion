# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Local build config (generated by sccache-setup)
.cargo/

# PostgreSQL test setup
pg-test-config.toml

# Profiling artifacts
flamegraph.svg
perf.data
perf.data.old

# Benchmark data files (e.g. ClickBench hits.tsv is ~75GB)
benches/clickbench/hits.tsv
benches/clickbench/results.csv

# TPC-H benchmark data and generator
benches/tpch/data_sf1/
benches/tpch/tpch-dbgen/

# Test output/results
tests/consistency/results.txt
tests/sql_correctness/results.txt
