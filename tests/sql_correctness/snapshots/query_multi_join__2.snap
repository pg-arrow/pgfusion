Query: SELECT a.aid, a.abalance,        b.bbalance,        t.tid, t.tbalance,        h.delta, h.mtime FROM pgbench_accounts a JOIN pgbench_branches b ON a.bid = b.bid JOIN pgbench_tellers t ON t.bid = b.bid JOIN pgbench_history h ON h.aid = a.aid WHERE a.aid <= 5 ORDER BY a.aid, t.tid, h.mtime

