Query: SELECT aid, abalance,        CAST(abalance AS BIGINT) * 1000000 AS scaled_up,        CAST(abalance AS DOUBLE) / 3.0 AS third FROM pgbench_accounts WHERE abalance != 0 ORDER BY ABS(abalance) DESC LIMIT 20

