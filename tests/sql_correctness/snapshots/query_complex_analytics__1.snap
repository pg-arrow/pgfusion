Query: SELECT     CASE         WHEN abalance < -1000 THEN 'very_negative'         WHEN abalance < 0     THEN 'negative'         WHEN abalance = 0     THEN 'zero'         WHEN abalance < 1000  THEN 'positive'         ELSE                       'very_positive'     END AS balance_bucket,     COUNT(*) AS num_accounts,     MIN(abalance) AS min_bal,     MAX(abalance) AS max_bal FROM pgbench_accounts GROUP BY     CASE         WHEN abalance < -1000 THEN 'very_negative'         WHEN abalance < 0     THEN 'negative'         WHEN abalance = 0     THEN 'zero'         WHEN abalance < 1000  THEN 'positive'         ELSE                       'very_positive'     END ORDER BY min_bal

