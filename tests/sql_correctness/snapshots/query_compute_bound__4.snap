Query: SELECT bid,        COUNT(*) AS cnt,        SUM(abalance) AS sum_bal,        AVG(abalance) AS avg_bal,        MIN(abalance) AS min_bal,        MAX(abalance) AS max_bal,        STDDEV(CAST(abalance AS DOUBLE)) AS stddev_bal,        SUM(CASE WHEN abalance > 0 THEN 1 ELSE 0 END) AS pos_count,        SUM(CASE WHEN abalance < 0 THEN 1 ELSE 0 END) AS neg_count,        SUM(CASE WHEN abalance = 0 THEN 1 ELSE 0 END) AS zero_count,        SUM(ABS(abalance)) AS total_abs_balance FROM pgbench_accounts GROUP BY bid ORDER BY bid

