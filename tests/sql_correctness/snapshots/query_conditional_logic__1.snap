Query: SELECT bid,        COUNT(*) AS total,        SUM(CASE WHEN abalance > 0 THEN 1 ELSE 0 END) AS positive_count,        SUM(CASE WHEN abalance = 0 THEN 1 ELSE 0 END) AS zero_count,        SUM(CASE WHEN abalance < 0 THEN 1 ELSE 0 END) AS negative_count FROM pgbench_accounts GROUP BY bid ORDER BY bid

