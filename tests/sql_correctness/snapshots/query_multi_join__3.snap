Query: SELECT a.aid, a.abalance,        b.bbalance,        h.delta,        COALESCE(h.delta, 0) AS delta_or_zero FROM pgbench_accounts a JOIN pgbench_branches b ON a.bid = b.bid LEFT JOIN pgbench_history h ON h.aid = a.aid WHERE a.aid <= 20 ORDER BY a.aid

