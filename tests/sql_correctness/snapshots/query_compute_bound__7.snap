Query: SELECT     CASE         WHEN abalance % 10 = 0 THEN 'mod10_0'         WHEN abalance % 10 < 5 THEN 'mod10_low'         ELSE                        'mod10_high'     END AS bucket,     COUNT(*) AS cnt,     AVG(abalance) AS avg_bal FROM pgbench_accounts GROUP BY     CASE         WHEN abalance % 10 = 0 THEN 'mod10_0'         WHEN abalance % 10 < 5 THEN 'mod10_low'         ELSE                        'mod10_high'     END ORDER BY bucket

