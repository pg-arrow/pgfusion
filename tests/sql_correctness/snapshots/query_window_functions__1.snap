Query: SELECT aid, bid, abalance,        ROW_NUMBER() OVER (PARTITION BY bid ORDER BY abalance DESC) AS rank_in_branch,        SUM(abalance) OVER (PARTITION BY bid) AS branch_total,        AVG(abalance) OVER (PARTITION BY bid) AS branch_avg FROM pgbench_accounts WHERE bid <= 5 ORDER BY bid, rank_in_branch LIMIT 50

