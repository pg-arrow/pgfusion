Query: SELECT aid,        UPPER('branch_' || CAST(bid AS VARCHAR)) AS upper_label,        LOWER('ACCOUNT_' || CAST(aid AS VARCHAR)) AS lower_label FROM pgbench_accounts WHERE aid <= 10 ORDER BY aid

