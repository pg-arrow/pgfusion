Query: WITH ranked_tellers AS (     SELECT t.tid, t.bid, t.tbalance,            RANK() OVER (PARTITION BY t.bid ORDER BY t.tbalance DESC) AS rnk     FROM pgbench_tellers t ) SELECT r.tid, r.bid, r.tbalance, r.rnk, b.bbalance FROM ranked_tellers r JOIN pgbench_branches b ON r.bid = b.bid WHERE r.rnk = 1 ORDER BY r.bid

